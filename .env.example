# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_SCHEMA="public"

# Optional: exact table name to use for sensor readings
VITE_SUPABASE_READINGS_TABLE=""

# Optional: fallback table candidates tried in order when table name is not set
VITE_SUPABASE_READINGS_TABLES="readings,sensor_readings,sensor_data,telemetry,measurements,historical_data"

# Playback simulation (realtime replay)
# Set to true only when you want demo playback instead of live data.
VITE_PLAYBACK_ENABLED="false"
VITE_PLAYBACK_START_TIMESTAMP="2025-09-01T00:00:00Z"
VITE_PLAYBACK_STEP_MINUTES="1"
VITE_PLAYBACK_TICK_MS="60000"
VITE_PLAYBACK_WINDOW_LIMIT="200"
VITE_PLAYBACK_ROWS_PER_MINUTE="20"
VITE_PLAYBACK_PADDING_MULTIPLIER="2"
